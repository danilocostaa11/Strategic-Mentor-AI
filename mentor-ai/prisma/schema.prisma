generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Client {
  id                String   @id @default(cuid())
  name              String
  company           String?
  segment           String?
  profileManual     String?
  profileAI         String?
  profileConfidence Float?
  profileConfirmed  Boolean  @default(false)
  tags              String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  meetings          Meeting[]
}

model Meeting {
  id                String   @id @default(cuid())
  clientId          String?
  title             String
  segment           String?
  rawTranscript     String
  analysisJson      String?
  analysisVersion   String?
  status            String   @default("PENDING")
  strategicScore    Float?
  closingScore      Float?
  listeningScore    Float?
  dealOutcome       String?  // GANHOU | PERDEU | EM_ANDAMENTO
  userFeedback      String?
  includedInPattern Boolean  @default(false)
  promptVersion     String?
  promptHash        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  client            Client?  @relation(fields: [clientId], references: [id])
}

model PatternReport {
  id         String   @id @default(cuid())
  meetingIds String
  reportJson String
  createdAt  DateTime @default(now())
}
