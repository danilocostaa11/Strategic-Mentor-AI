# SQLite Database (Desenvolvimento Local)
DATABASE_URL=file:./prisma/dev.db

# Turso Database Configuration (Produção - Vercel)
TURSO_DATABASE_URL=libsql://SEU_DATABASE_URL_AQUI
TURSO_AUTH_TOKEN=SEU_AUTH_TOKEN_AQUI

# OpenAI API Configuration
OPENAI_API_KEY=sua-chave-openai-aqui
AI_INTEGRATIONS_OPENAI_API_KEY=sua-chave-openai-aqui
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Modelo de IA (OpenAI-compatible endpoint, ex: Gemini via proxy)
AI_MODEL_PRIMARY=gemini-2.5-pro
AI_MODEL_FALLBACK=gemini-2.5-flash

# Auto-publish ao vault Obsidian (Estágio 2 — Mentor AI → GitHub)
# Quando VAULT_AUTOPUBLISH=true, toda análise concluída é commitada como .md
# no repo configurado. Path é derivado de segmento + título + data
# (ver lib/vault-formatter.ts → resolveVaultPath).
# R-AZ2: segmento Pharma é bloqueado nativamente.
VAULT_AUTOPUBLISH=false
GITHUB_TOKEN=ghp_seu_personal_access_token_com_scope_repo
VAULT_REPO_OWNER=danilocostaa11
VAULT_REPO_NAME=segundo-cerebro
VAULT_BRANCH=main
